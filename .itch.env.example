# Copy this file to ".itch.env" and fill in the values.
# ".itch.env" is gitignored and must NEVER be committed.
#
# Get your API key from: https://itch.io/user/settings/api-keys
BUTLER_API_KEY=

# Your itch.io username (the account that owns the game page).
ITCH_USER=

# The game's URL slug on itch.io (https://ITCH_USER.itch.io/ITCH_GAME).
ITCH_GAME=chairfighter

# butler channel. "html5" makes the build playable in-browser on the page.
ITCH_CHANNEL=html5
